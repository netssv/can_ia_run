---
import Layout from "@/layouts/Layout.astro";
import NavHeader from "@/components/NavHeader.astro";
import Footer from "@/components/Footer.astro";

const PAYPAL_CLIENT_ID = "ARepW6o2yp0OO13yXEIRaWYJ_AlWzGVF2bGCdnQ2h54YFUyATFm892Ihpz2ZEy4iDocKllZz8RbwTLbb";
---

<Layout title="Advertise on CanIRun.ai" description="Reach developers and AI enthusiasts. Advertise your product on CanIRun.ai.">
  <NavHeader />
  <main class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <header class="mb-10 text-center">
      <h1 class="font-pixel text-2xl tracking-tight text-accent sm:text-3xl">Advertise</h1>
      <p class="mt-2 text-sm text-muted">
        Reach thousands of developers and AI enthusiasts who run models locally.
      </p>
    </header>

    <!-- What you get -->
    <section class="mb-10">
      <h2 class="mb-3 font-pixel text-xs uppercase tracking-wider text-muted">What's included</h2>
      <ul class="space-y-2 font-mono text-xs text-secondary">
        <li class="flex items-start gap-2">
          <span class="text-accent">›</span>
          Banner placement visible on all pages (home, model detail, docs)
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent">›</span>
          Direct link to your website or product
        </li>
        <li class="flex items-start gap-2">
          <span class="text-accent">›</span>
          Your ad starts within 24 hours of payment confirmation
        </li>
      </ul>
    </section>

    <!-- Pricing tiers -->
    <section class="mb-12">
      <h2 class="mb-4 font-pixel text-xs uppercase tracking-wider text-muted">Pricing</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        <!-- Starter -->
        <div class="rounded-lg border border-edge/60 bg-surface-card p-5">
          <h3 class="font-pixel text-sm text-primary">Starter</h3>
          <p class="mt-0.5 font-mono text-[11px] text-muted">1 week</p>
          <p class="mt-3 font-pixel text-2xl text-accent">$49</p>
          <div class="mt-4">
            <button
              type="button"
              data-tier="starter"
              data-price="49.00"
              data-label="CanIRun.ai Ad — Starter (1 week)"
              class="ad-buy-btn w-full rounded-md border border-edge bg-surface-hover px-4 py-2 font-mono text-[11px] text-secondary transition-colors hover:border-accent/30 hover:text-accent"
            >
              Buy Now
            </button>
          </div>
        </div>

        <!-- Growth -->
        <div class="rounded-lg border border-accent/20 bg-surface-card p-5 ring-1 ring-accent/5">
          <div class="flex items-center gap-2">
            <h3 class="font-pixel text-sm text-primary">Growth</h3>
            <span class="rounded-full bg-accent/10 px-1.5 py-px font-mono text-[9px] text-accent">Popular</span>
          </div>
          <p class="mt-0.5 font-mono text-[11px] text-muted">2 weeks</p>
          <p class="mt-3 font-pixel text-2xl text-accent">$89</p>
          <div class="mt-4">
            <button
              type="button"
              data-tier="growth"
              data-price="89.00"
              data-label="CanIRun.ai Ad — Growth (2 weeks)"
              class="ad-buy-btn w-full rounded-md bg-accent px-4 py-2 font-mono text-[11px] font-medium text-surface transition-colors hover:bg-accent/90"
            >
              Buy Now
            </button>
          </div>
        </div>

        <!-- Premium -->
        <div class="rounded-lg border border-edge/60 bg-surface-card p-5">
          <h3 class="font-pixel text-sm text-primary">Premium</h3>
          <p class="mt-0.5 font-mono text-[11px] text-muted">1 month</p>
          <p class="mt-3 font-pixel text-2xl text-accent">$149</p>
          <div class="mt-4">
            <button
              type="button"
              data-tier="premium"
              data-price="149.00"
              data-label="CanIRun.ai Ad — Premium (1 month)"
              class="ad-buy-btn w-full rounded-md border border-edge bg-surface-hover px-4 py-2 font-mono text-[11px] text-secondary transition-colors hover:border-accent/30 hover:text-accent"
            >
              Buy Now
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- Ad Info Modal -->
    <div id="ad-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-surface/80 backdrop-blur-sm">
      <div class="mx-4 w-full max-w-md rounded-lg border border-edge bg-surface-card p-6">
        <h3 class="mb-4 font-pixel text-sm text-primary">Ad Details</h3>
        <p class="mb-1 font-mono text-[11px] text-muted">Fill in your ad information before proceeding to payment.</p>
        <p id="modal-tier-label" class="mb-4 font-mono text-[11px] text-accent"></p>
        <div class="space-y-3">
          <div>
            <label for="ad-title" class="mb-1 block font-mono text-[10px] uppercase tracking-wider text-muted">Ad Title</label>
            <input id="ad-title" type="text" placeholder="Your product name" class="w-full rounded-md border border-edge bg-surface px-3 py-2 font-mono text-xs text-primary placeholder:text-muted/40 focus:border-accent/40 focus:outline-none" />
          </div>
          <div>
            <label for="ad-description" class="mb-1 block font-mono text-[10px] uppercase tracking-wider text-muted">Short Description</label>
            <input id="ad-description" type="text" placeholder="One line about your product" class="w-full rounded-md border border-edge bg-surface px-3 py-2 font-mono text-xs text-primary placeholder:text-muted/40 focus:border-accent/40 focus:outline-none" />
          </div>
          <div>
            <label for="ad-url" class="mb-1 block font-mono text-[10px] uppercase tracking-wider text-muted">Link URL</label>
            <input id="ad-url" type="url" placeholder="https://yoursite.com" class="w-full rounded-md border border-edge bg-surface px-3 py-2 font-mono text-xs text-primary placeholder:text-muted/40 focus:border-accent/40 focus:outline-none" />
          </div>
        </div>
        <!-- PayPal buttons render here -->
        <div id="paypal-button-container" class="mt-5"></div>
        <button id="ad-cancel" class="mt-2 w-full rounded-md border border-edge px-4 py-2 font-mono text-[11px] text-muted transition-colors hover:text-secondary">
          Cancel
        </button>
      </div>
    </div>

    <!-- Custom campaigns -->
    <section class="rounded-lg border border-edge/40 bg-surface-card p-6 text-center">
      <p class="font-mono text-xs text-secondary">
        Need a custom campaign or longer duration?
      </p>
      <p class="mt-2 font-mono text-xs">
        <a href="mailto:miduga@gmail.com" class="text-accent underline decoration-accent/30 underline-offset-2 hover:decoration-accent">
          miduga@gmail.com
        </a>
      </p>
    </section>

    <Footer />
  </main>
</Layout>

<!-- PayPal JS SDK -->
<script is:inline define:vars={{ PAYPAL_CLIENT_ID }}>
  // Load PayPal SDK dynamically
  const script = document.createElement("script");
  script.src = `https://www.paypal.com/sdk/js?client-id=${PAYPAL_CLIENT_ID}&currency=USD&disable-funding=card,credit,paylater,venmo,bancontact,blik,eps,giropay,ideal,mybank,p24,sepa,sofort`;
  script.async = true;
  script.onload = () => initPayPal();
  document.head.appendChild(script);

  let currentPrice = "0";
  let currentLabel = "";

  const modal = document.getElementById("ad-modal");
  const titleInput = document.getElementById("ad-title");
  const descInput = document.getElementById("ad-description");
  const urlInput = document.getElementById("ad-url");
  const cancelBtn = document.getElementById("ad-cancel");
  const tierLabel = document.getElementById("modal-tier-label");
  const btnContainer = document.getElementById("paypal-button-container");

  // Open modal on tier click
  document.querySelectorAll(".ad-buy-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      currentPrice = btn.dataset.price;
      currentLabel = btn.dataset.label;
      tierLabel.textContent = `${currentLabel} — $${currentPrice}`;
      titleInput.value = "";
      descInput.value = "";
      urlInput.value = "";
      modal.classList.remove("hidden");
      modal.classList.add("flex");
      titleInput.focus();
    });
  });

  // Close modal
  function closeModal() {
    modal.classList.add("hidden");
    modal.classList.remove("flex");
  }

  cancelBtn.addEventListener("click", closeModal);
  modal.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });
  document.addEventListener("keydown", (e) => { if (e.key === "Escape") closeModal(); });

  function initPayPal() {
    paypal.Buttons({
      style: {
        layout: "vertical",
        color: "gold",
        shape: "rect",
        label: "paypal",
        height: 40,
      },

      createOrder(data, actions) {
        const title = titleInput.value.trim();
        const url = urlInput.value.trim();

        if (!title) { titleInput.focus(); return; }
        if (!url) { urlInput.focus(); return; }

        return actions.order.create({
          purchase_units: [{
            description: `${currentLabel} | ${title} — ${descInput.value.trim()} | ${url}`,
            amount: {
              value: currentPrice,
              currency_code: "USD",
            },
          }],
        });
      },

      onApprove(data, actions) {
        return actions.order.capture().then(details => {
          closeModal();
          const name = details.payer?.name?.given_name || "there";
          alert(`Thanks ${name}! Your ad "${titleInput.value}" will be live within 24 hours.`);
        });
      },

      onError(err) {
        console.error("PayPal error:", err);
      },
    }).render("#paypal-button-container");
  }
</script>
