---
import Layout from "../layouts/Layout.astro";
import NavHeader from "../components/NavHeader.astro";
import { models } from "../data/models";
import IconCpu from "../icons/cpu.svg";
import IconRam from "../icons/ram.svg";
import IconGpu from "../icons/gpu.svg";
import IconBandwidth from "../icons/bandwidth.svg";
import IconCheck from "../icons/check.svg";
import IconSearch from "../icons/search.svg";
import IconGrid from "../icons/grid.svg";
import IconGridDots from "../icons/grid-dots.svg";
import IconList from "../icons/list.svg";
import IconMoe from "../icons/moe.svg";
import IconTool from "../icons/tool.svg";
import IconThinking from "../icons/thinking.svg";
import IconVision from "../icons/vision.svg";
import IconStar from "../icons/star.svg";

const sortedModels = [...models].sort(
  (a, b) => a.paramsBillions - b.paramsBillions
);
const featuredModels = sortedModels.filter((m) => m.featured);
const otherModels = sortedModels.filter((m) => !m.featured);

const providers = [...new Set(models.map((m) => m.provider))].sort();

function timeAgo(dateStr: string | null): string {
  if (!dateStr) return "";
  const now = new Date();
  const date = new Date(dateStr + "-01");
  const diffMs = now.getTime() - date.getTime();
  const days = Math.floor(diffMs / (1000 * 60 * 60 * 24));
  if (days < 0) return "upcoming";
  if (days === 0) return "today";
  if (days === 1) return "1 day ago";
  if (days < 30) return `${days}d ago`;
  const months = Math.floor(days / 30);
  if (months === 1) return "1 month ago";
  if (months < 12) return `${months}mo ago`;
  const years = Math.floor(months / 12);
  if (years === 1) return "1 year ago";
  return `${years}y ago`;
}
---

<Layout>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "CanIRun.ai",
      "url": "https://canirun.ai",
      "description": "Detect your hardware and find out which AI models you can run locally. GPU, CPU, and RAM analysis in your browser.",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "Web Browser",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "creator": { "@type": "Person", "name": "midudev", "url": "https://midu.dev" }
    })}></script>
  </Fragment>
  <NavHeader />
  <main id="results" class="mx-auto max-w-6xl px-4 pb-20 pt-10 sm:px-6">
    <!-- Header -->
    <header class="mb-10 text-center">
      <h1 class="font-pixel text-3xl tracking-tight text-accent sm:text-4xl">
        Can I Run AI locally?
      </h1>
      <p class="mt-2 text-sm text-muted">
        Find out which AI models your machine can actually run.
      </p>
    </header>

    <!-- Hardware Panel — fixed height to prevent CLS -->
    <section id="hw-panel" class="mb-10 min-h-[52px]">
      <div id="hw-bar" class="flex flex-wrap items-center justify-center gap-x-4 gap-y-1.5 font-mono text-xs text-secondary">
        <!-- GPU (most important for AI) -->
        <span id="hw-gpu" class="inline-flex items-center gap-1.5 text-muted max-w-[50ch]">
          <IconGpu class="h-3.5 w-3.5 shrink-0" />
          <span class="truncate">detecting...</span>
        </span>
        <span class="text-edge/40">|</span>
        <!-- RAM -->
        <span id="hw-ram" class="inline-flex items-center gap-1.5 text-muted">
          <IconRam class="h-3.5 w-3.5 shrink-0" />
          <span>—</span>
        </span>
        <!-- Bandwidth -->
        <span id="hw-bw" class="hidden inline-flex items-center gap-1.5">
          <span class="text-edge/40">|</span>
          <IconBandwidth class="h-3.5 w-3.5 shrink-0 text-muted" />
          <span id="hw-bw-val"></span>
        </span>
        <!-- GPU Cores -->
        <span id="hw-gpu-cores" class="hidden inline-flex items-center gap-1.5">
          <span class="text-edge/40">|</span>
          <IconCpu class="h-3.5 w-3.5 shrink-0 text-muted" stroke-width="1.5" />
          <span id="hw-gpu-cores-val"></span>
        </span>
        <!-- WebGPU -->
        <span id="hw-webgpu-badge" class="hidden inline-flex items-center gap-1 rounded-full border border-accent/30 bg-accent/10 px-2 py-0.5 text-[10px] text-accent">
          <IconCheck class="h-3 w-3" />
          <span>WebGPU</span>
        </span>
      </div>
      <p id="hw-notice" class="mt-1.5 text-center text-[10px] text-muted invisible">
        Estimates based on browser APIs. Actual specs may vary.
      </p>
    </section>

    <!-- Summary counters — grade distribution -->
    <div id="summary-bar" class="mb-8 invisible">
      <div class="flex items-center justify-center gap-4 font-mono text-[11px] sm:gap-6">
        <span class="flex items-center gap-1" style="color: var(--color-can-run)">
          <span class="font-pixel text-xs">S</span>
          <span id="count-s" class="font-bold">0</span>
        </span>
        <span class="flex items-center gap-1" style="color: var(--color-grade-a)">
          <span class="font-pixel text-xs">A</span>
          <span id="count-a" class="font-bold">0</span>
        </span>
        <span class="flex items-center gap-1" style="color: var(--color-grade-b)">
          <span class="font-pixel text-xs">B</span>
          <span id="count-b" class="font-bold">0</span>
        </span>
        <span class="flex items-center gap-1" style="color: var(--color-maybe)">
          <span class="font-pixel text-xs">C</span>
          <span id="count-c" class="font-bold">0</span>
        </span>
        <span class="flex items-center gap-1" style="color: var(--color-grade-d)">
          <span class="font-pixel text-xs">D</span>
          <span id="count-d" class="font-bold">0</span>
        </span>
        <span class="flex items-center gap-1" style="color: var(--color-cannot-run)">
          <span class="font-pixel text-xs">F</span>
          <span id="count-f" class="font-bold">0</span>
        </span>
      </div>
    </div>

    <!-- Search + Filters bar (single line) -->
    <div class="mb-6 flex flex-wrap items-center gap-2">
      <!-- Search -->
      <div class="relative flex-1 min-w-[180px] max-w-xs">
        <IconSearch class="pointer-events-none absolute left-2.5 top-1/2 h-3.5 w-3.5 -translate-y-1/2 text-muted" />
        <input
          id="search-input"
          type="text"
          placeholder="Search models..."
          class="filter-select w-full !pl-8 pr-8"
          autocomplete="off"
        />
        <kbd class="pointer-events-none absolute right-2 top-1/2 hidden -translate-y-1/2 rounded border border-edge/60 bg-surface-raised px-1.5 py-0.5 font-mono text-[10px] leading-none text-secondary shadow-[0_1px_0_0_var(--color-edge)] sm:inline-block">/</kbd>
      </div>

      <span class="hidden h-4 w-px bg-edge/40 sm:block"></span>

      <!-- Status filter -->
      <select id="filter-status" class="filter-select">
        <option value="all">All grades</option>
        <option value="featured">Popular</option>
        <option value="can-run">Can run (S/A/B)</option>
        <option value="tight">Tight fit (C/D)</option>
        <option value="cannot-run">Too heavy (F)</option>
      </select>

      <!-- Use case filter -->
      <select id="filter-use" class="filter-select">
        <option value="all">All tasks</option>
        <option value="chat">Chat</option>
        <option value="code">Code</option>
        <option value="reasoning">Reasoning</option>
        <option value="vision">Vision</option>
      </select>

      <!-- Provider filter -->
      <select id="filter-provider" class="filter-select">
        <option value="all">All providers</option>
        {providers.map((p) => (
          <option value={p}>{p}</option>
        ))}
      </select>

      <!-- Sort -->
      <select id="sort-select" class="filter-select">
        <option value="score">Sort: Score</option>
        <option value="params-asc">Sort: Params ↑</option>
        <option value="params-desc">Sort: Params ↓</option>
        <option value="release">Sort: Newest</option>
        <option value="context">Sort: Context</option>
        <option value="toks">Sort: Speed</option>
        <option value="vram">Sort: VRAM ↑</option>
      </select>

      <span class="hidden h-4 w-px bg-edge/40 sm:block"></span>

      <!-- View mode toggle -->
      <button id="view-toggle" class="filter-select hidden items-center gap-1.5 cursor-pointer sm:inline-flex" title="Toggle view mode">
        <!-- Simple: grid icon -->
        <IconGrid id="view-icon-simple" class="h-3 w-3" />
        <!-- Advanced: detailed grid icon -->
        <IconGridDots id="view-icon-advanced" class="hidden h-3 w-3" />
        <!-- List: rows icon -->
        <IconList id="view-icon-list" class="hidden h-3 w-3" />
        <span id="view-label" class="text-[10px]">Simple</span>
      </button>
    </div>

    <!-- Popular models -->
    <div id="models-grid" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {featuredModels.map((model) => (
        <a href={`/model/${model.id}`} class="block">
          <article
            data-model-id={model.id}
            data-model-name={model.name}
            data-quants={JSON.stringify(model.quants)}
            data-params={model.paramsBillions}
            data-arch={model.architecture}
            data-uses={model.useCase.join(",")}
            data-provider={model.provider}
            data-context={model.contextLength}
            data-release={model.releaseDate || ""}
            data-featured="true"
            class="model-card group relative flex h-full flex-col rounded-lg border border-edge/60 bg-black transition-all hover:border-accent/30 hover:bg-surface-hover"
          >
            <div data-card-body class="flex flex-col p-4 pb-3">
              <div data-card-top class="min-w-0">
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0">
                    <h3 class="truncate font-pixel text-sm text-primary" transition:name={`model-title-${model.id}`}>{model.name}</h3>
                    {model.architecture === "moe" && (
                      <span class="shrink-0 rounded border border-info/20 bg-info/5 p-0.5 text-info" title="Mixture of Experts">
                        <IconMoe class="h-3 w-3" />
                      </span>
                    )}
                    {model.tools && (
                      <span class="shrink-0 rounded border border-purple-400/30 bg-purple-400/10 p-0.5 text-purple-400" title="Tool Use">
                        <IconTool class="h-3 w-3" />
                      </span>
                    )}
                    {model.thinking && (
                      <span class="shrink-0 rounded border border-sky-400/30 bg-sky-400/10 p-0.5 text-sky-400" title="Thinking / Reasoning">
                        <IconThinking class="h-3 w-3" />
                      </span>
                    )}
                    {model.useCase.includes("vision") && (
                      <span class="shrink-0 rounded border border-rose-400/30 bg-rose-400/10 p-0.5 text-rose-400" title="Vision">
                        <IconVision class="h-3 w-3" />
                      </span>
                    )}
                    <span class="shrink-0 rounded border border-yellow-400/30 bg-yellow-400/10 p-0.5 text-yellow-400" title="Popular">
                      <IconStar class="h-3 w-3" />
                    </span>
                  </div>
                  {model.releaseDate && (
                    <span class="shrink-0 font-mono text-[9px] text-muted/60">{timeAgo(model.releaseDate)}</span>
                  )}
                </div>
                <p data-card-provider class="mt-0.5 font-mono text-[11px] text-muted">
                  {model.provider} · {model.params}
                </p>
                <p data-description class="mt-1 text-[11px] leading-snug text-secondary/60 italic">{model.description}</p>
              </div>
              <div data-card-stats class="mt-3 flex items-center gap-3 font-mono text-[11px]">
                <span class="inline-flex items-center gap-1 text-muted"><span data-vram-val class="text-secondary">{(model.quants.find(q => q.name === "Q4_K_M") || model.quants[0]).vramGB}</span> GB <span data-mem-pct-pill class="hidden rounded-full px-1.5 py-px text-[9px] font-medium" data-mem-pct></span></span>
                <span class="text-edge/40">·</span>
                <span class="text-muted"><span class="text-secondary">{model.contextLength >= 1024 ? `${Math.round(model.contextLength / 1024)}K` : model.contextLength}</span> ctx</span>
                <span class="text-edge/40">·</span>
                <span data-tok-speed class="text-muted"></span>
              </div>
              <div data-advanced class="mt-3 hidden border-t border-edge/30 pt-3">
                <div class="mb-2 flex flex-wrap gap-1">
                  {model.quants.map((q, i) => (
                    <button
                      data-quant-btn={i}
                      class={`quant-btn rounded px-1.5 py-0.5 text-[10px] font-mono transition-colors ${i === 2 ? "border border-accent/30 bg-accent/10 text-accent" : "border border-transparent text-muted hover:text-secondary"}`}
                    >
                      {q.name}
                    </button>
                  ))}
                </div>
                <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[10px]">
                  <div class="flex justify-between">
                    <span class="text-muted">Released</span>
                    <span class="font-mono text-secondary">{model.releaseDate}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-muted">Architecture</span>
                    <span class="font-mono text-secondary">{model.architecture === "moe" ? "MoE" : "Dense"}</span>
                  </div>
                  {model.activeParams && (
                    <div class="flex justify-between">
                      <span class="text-muted">Active</span>
                      <span class="font-mono text-secondary">{model.activeParams}</span>
                    </div>
                  )}
                  <div data-mem-pct-row class="flex justify-between">
                    <span class="text-muted">Memory</span>
                    <span data-mem-pct-detail class="font-mono text-secondary">—</span>
                  </div>
                </div>
                <div class="mt-2 flex flex-wrap gap-1">
                  {model.useCase.map((tag) => (
                    <span class="rounded border border-edge/40 px-1.5 py-0.5 text-[9px] text-muted">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
            <div data-card-footer class="mt-auto flex items-center justify-between px-4 pb-3">
              <span class="inline-flex items-center gap-1.5">
                <span data-status-dot class="h-2 w-2 shrink-0 rounded-full bg-muted/30 transition-colors"></span>
                <span data-status-label class="font-mono text-[9px] font-medium uppercase tracking-wider text-muted"></span>
              </span>
              <span class="flex flex-col items-center">
                <span data-score class="font-pixel text-lg leading-none text-muted"></span>
                <span data-score-num class="font-mono text-[9px] text-muted/50"></span>
              </span>
            </div>
          </article>
        </a>
      ))}
    </div>

    <!-- Section divider -->
    <div id="rest-divider" class="my-8 flex items-center gap-4">
      <div class="h-px flex-1 bg-edge/30"></div>
      <span class="font-mono text-[11px] text-muted/60">All models</span>
      <div class="h-px flex-1 bg-edge/30"></div>
    </div>

    <!-- Rest of models -->
    <div id="models-grid-rest" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {otherModels.map((model) => (
        <a href={`/model/${model.id}`} class="block">
          <article
            data-model-id={model.id}
            data-model-name={model.name}
            data-quants={JSON.stringify(model.quants)}
            data-params={model.paramsBillions}
            data-arch={model.architecture}
            data-uses={model.useCase.join(",")}
            data-provider={model.provider}
            data-context={model.contextLength}
            data-release={model.releaseDate || ""}
            class="model-card group relative flex h-full flex-col rounded-lg border border-edge/60 bg-black transition-all hover:border-accent/30 hover:bg-surface-hover"
          >
            <div data-card-body class="flex flex-col p-4 pb-3">
              <div data-card-top class="min-w-0">
                <div class="flex items-center justify-between gap-2">
                  <div class="flex items-center gap-2 min-w-0">
                    <h3 class="truncate font-pixel text-sm text-primary" transition:name={`model-title-${model.id}`}>{model.name}</h3>
                    {model.architecture === "moe" && (
                      <span class="shrink-0 rounded border border-info/20 bg-info/5 p-0.5 text-info" title="Mixture of Experts">
                        <IconMoe class="h-3 w-3" />
                      </span>
                    )}
                    {model.tools && (
                      <span class="shrink-0 rounded border border-purple-400/30 bg-purple-400/10 p-0.5 text-purple-400" title="Tool Use">
                        <IconTool class="h-3 w-3" />
                      </span>
                    )}
                    {model.thinking && (
                      <span class="shrink-0 rounded border border-sky-400/30 bg-sky-400/10 p-0.5 text-sky-400" title="Thinking / Reasoning">
                        <IconThinking class="h-3 w-3" />
                      </span>
                    )}
                    {model.useCase.includes("vision") && (
                      <span class="shrink-0 rounded border border-rose-400/30 bg-rose-400/10 p-0.5 text-rose-400" title="Vision">
                        <IconVision class="h-3 w-3" />
                      </span>
                    )}
                  </div>
                  {model.releaseDate && (
                    <span class="shrink-0 font-mono text-[9px] text-muted/60">{timeAgo(model.releaseDate)}</span>
                  )}
                </div>
                <p data-card-provider class="mt-0.5 font-mono text-[11px] text-muted">
                  {model.provider} · {model.params}
                </p>
                <p data-description class="mt-1 text-[11px] leading-snug text-secondary/60 italic">{model.description}</p>
              </div>
              <div data-card-stats class="mt-3 flex items-center gap-3 font-mono text-[11px]">
                <span class="inline-flex items-center gap-1 text-muted"><span data-vram-val class="text-secondary">{(model.quants.find(q => q.name === "Q4_K_M") || model.quants[0]).vramGB}</span> GB <span data-mem-pct-pill class="hidden rounded-full px-1.5 py-px text-[9px] font-medium" data-mem-pct></span></span>
                <span class="text-edge/40">·</span>
                <span class="text-muted"><span class="text-secondary">{model.contextLength >= 1024 ? `${Math.round(model.contextLength / 1024)}K` : model.contextLength}</span> ctx</span>
                <span class="text-edge/40">·</span>
                <span data-tok-speed class="text-muted"></span>
              </div>
              <div data-advanced class="mt-3 hidden border-t border-edge/30 pt-3">
                <div class="mb-2 flex flex-wrap gap-1">
                  {model.quants.map((q, i) => (
                    <button
                      data-quant-btn={i}
                      class={`quant-btn rounded px-1.5 py-0.5 text-[10px] font-mono transition-colors ${i === 2 ? "border border-accent/30 bg-accent/10 text-accent" : "border border-transparent text-muted hover:text-secondary"}`}
                    >
                      {q.name}
                    </button>
                  ))}
                </div>
                <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-[10px]">
                  <div class="flex justify-between">
                    <span class="text-muted">Released</span>
                    <span class="font-mono text-secondary">{model.releaseDate}</span>
                  </div>
                  <div class="flex justify-between">
                    <span class="text-muted">Architecture</span>
                    <span class="font-mono text-secondary">{model.architecture === "moe" ? "MoE" : "Dense"}</span>
                  </div>
                  {model.activeParams && (
                    <div class="flex justify-between">
                      <span class="text-muted">Active</span>
                      <span class="font-mono text-secondary">{model.activeParams}</span>
                    </div>
                  )}
                  <div data-mem-pct-row class="flex justify-between">
                    <span class="text-muted">Memory</span>
                    <span data-mem-pct-detail class="font-mono text-secondary">—</span>
                  </div>
                </div>
                <div class="mt-2 flex flex-wrap gap-1">
                  {model.useCase.map((tag) => (
                    <span class="rounded border border-edge/40 px-1.5 py-0.5 text-[9px] text-muted">{tag}</span>
                  ))}
                </div>
              </div>
            </div>
            <div data-card-footer class="mt-auto flex items-center justify-between px-4 pb-3">
              <span class="inline-flex items-center gap-1.5">
                <span data-status-dot class="h-2 w-2 shrink-0 rounded-full bg-muted/30 transition-colors"></span>
                <span data-status-label class="font-mono text-[9px] font-medium uppercase tracking-wider text-muted"></span>
              </span>
              <span class="flex flex-col items-center">
                <span data-score class="font-pixel text-lg leading-none text-muted"></span>
                <span data-score-num class="font-mono text-[9px] text-muted/50"></span>
              </span>
            </div>
          </article>
        </a>
      ))}
    </div>

    <!-- Data source -->
    <p class="mt-20 text-center text-[11px] text-muted/50">
      Data sourced from <a href="https://github.com/ggerganov/llama.cpp" target="_blank" rel="noopener" class="text-muted/70 underline decoration-edge underline-offset-2 hover:text-primary">llama.cpp</a>, <a href="https://ollama.com" target="_blank" rel="noopener" class="text-muted/70 underline decoration-edge underline-offset-2 hover:text-primary">Ollama</a> and <a href="https://lmstudio.ai" target="_blank" rel="noopener" class="text-muted/70 underline decoration-edge underline-offset-2 hover:text-primary">LM Studio</a>.
    </p>

    <!-- Footer -->
    <footer class="mt-3 text-center text-xs text-muted/60">
      <p>
        Built by <a href="https://midu.dev" target="_blank" rel="noopener" class="text-muted underline decoration-edge underline-offset-2 hover:text-primary">midudev</a>
      </p>
    </footer>
  </main>
</Layout>

<script>
  import {
    detectHardware,
    evaluateModel,
    estimateTokensPerSecond,
    computeScore,
    scoreToGrade,
    memoryPercentage,
    getDisplayName,
    GRADES as _GRADES,
  } from "../lib/hardware";
  import type { HardwareInfo, ModelStatus, Grade, GradeInfo } from "../lib/hardware";

  // Override GRADES to use CSS variables for theming
  const GRADES: Record<Grade, GradeInfo> = {
    "S": { letter: "S",  label: "Runs great",  color: "var(--color-can-run)" },
    "A": { letter: "A",  label: "Runs well",   color: "var(--color-grade-a)" },
    "B": { letter: "B",  label: "Decent",       color: "var(--color-grade-b)" },
    "C": { letter: "C",  label: "Tight fit",    color: "var(--color-maybe)" },
    "D": { letter: "D",  label: "Barely runs",  color: "var(--color-grade-d)" },
    "F": { letter: "F",  label: "Too heavy",    color: "var(--color-cannot-run)" },
    "?": { letter: "?",  label: "Unknown",      color: "var(--color-muted)" },
  };

  const STATUS_COLORS: Record<ModelStatus, string> = {
    "can-run": "var(--color-can-run)",
    "tight": "var(--color-maybe)",
    "cannot-run": "var(--color-cannot-run)",
    "unknown": "var(--color-muted)",
  };

  // ── Main Logic ─────────────────────────────────────────────

  let currentHW: HardwareInfo;

  function updateHardwarePanel(hw: HardwareInfo) {
    const $ = (id: string) => document.getElementById(id);

    const gpuText = $("hw-gpu")!.querySelector("span")!;
    const displayName = getDisplayName(hw);
    gpuText.textContent = hw.estimatedVRAM ? `${displayName} (${hw.estimatedVRAM} GB)` : displayName;
    $("hw-gpu")!.classList.replace("text-muted", "text-secondary");

    const ramText = $("hw-ram")!.querySelector("span")!;
    ramText.textContent = hw.ramGB ? `${hw.ramGB} GB` : "Unknown";
    $("hw-ram")!.classList.replace("text-muted", "text-secondary");

    if (hw.memoryBandwidth) {
      const bwSpan = $("hw-bw")!;
      bwSpan.classList.remove("hidden");
      $("hw-bw-val")!.textContent = `~${hw.memoryBandwidth} GB/s`;
    }

    if (hw.gpuCores) {
      $("hw-gpu-cores")!.classList.remove("hidden");
      $("hw-gpu-cores-val")!.textContent = `${hw.gpuCores.toLocaleString()} GPU cores`;
    }

    $("hw-notice")!.classList.remove("invisible");
    if (hw.webgpu) $("hw-webgpu-badge")!.classList.remove("hidden");
  }

  function updateModelCard(card: HTMLElement, hw: HardwareInfo, quantIndex: number = 0) {
    const quants = JSON.parse(card.dataset.quants || "[]");
    const quant = quants[quantIndex] || quants[0];
    if (!quant) return;

    const vram = quant.vramGB;
    const status = evaluateModel(vram, hw);
    const toks = estimateTokensPerSecond(vram, hw);
    const params = parseFloat(card.dataset.params || "0");
    const memPct = memoryPercentage(vram, hw);
    const score = computeScore(status, toks, params, memPct);

    const grade = scoreToGrade(score, status);
    const gradeInfo = GRADES[grade];

    // Status dot — use grade color
    const dot = card.querySelector<HTMLElement>("[data-status-dot]");
    if (dot) dot.style.backgroundColor = gradeInfo.color;

    // Status label — show grade label (bottom left)
    const label = card.querySelector<HTMLElement>("[data-status-label]");
    if (label) {
      label.textContent = gradeInfo.label;
      label.style.color = gradeInfo.color;
    }

    // Grade letter — bottom right, large, full opacity
    const scoreEl = card.querySelector<HTMLElement>("[data-score]");
    if (scoreEl) {
      scoreEl.textContent = gradeInfo.letter;
      scoreEl.style.color = gradeInfo.color;
    }
    // Numerical score below grade
    const scoreNumEl = card.querySelector<HTMLElement>("[data-score-num]");
    if (scoreNumEl && score > 0) {
      scoreNumEl.textContent = `${score}/100`;
      scoreNumEl.style.color = gradeInfo.color;
    }

    card.dataset.grade = grade;

    // Memory % — pill in simple mode
    const memPill = card.querySelector<HTMLElement>("[data-mem-pct-pill]");
    if (memPill) {
      if (memPct !== null) {
        memPill.textContent = `${memPct}%`;
        memPill.classList.remove("hidden");
        if (memPct > 100) {
          memPill.className = "rounded-full bg-cannot-run/15 px-1.5 py-px text-[9px] font-medium text-cannot-run";
        } else if (memPct > 75) {
          memPill.className = "rounded-full bg-maybe/15 px-1.5 py-px text-[9px] font-medium text-maybe";
        } else {
          memPill.className = "rounded-full bg-can-run/15 px-1.5 py-px text-[9px] font-medium text-can-run";
        }
      }
    }
    // Memory % — detail in advanced mode
    const memDetail = card.querySelector<HTMLElement>("[data-mem-pct-detail]");
    if (memDetail) {
      if (memPct !== null) {
        memDetail.textContent = `${memPct}%`;
        if (memPct > 100) memDetail.style.color = "var(--color-cannot-run)";
        else if (memPct > 75) memDetail.style.color = "var(--color-maybe)";
        else memDetail.style.color = "var(--color-can-run)";
      } else {
        memDetail.textContent = "—";
      }
    }

    // Tokens/s with color coding
    const tokEl = card.querySelector<HTMLElement>("[data-tok-speed]");
    if (tokEl) {
      if (toks !== null && status !== "cannot-run") {
        tokEl.textContent = `~${toks} tok/s`;
        // Color based on speed
        if (toks >= 60) tokEl.className = "font-mono text-[11px] text-can-run";
        else if (toks >= 30) tokEl.className = "font-mono text-[11px] text-can-run/70";
        else if (toks >= 15) tokEl.className = "font-mono text-[11px] text-maybe";
        else if (toks >= 5) tokEl.className = "font-mono text-[11px] text-maybe/70";
        else tokEl.className = "font-mono text-[11px] text-cannot-run";
      } else {
        tokEl.textContent = "";
        tokEl.className = "font-mono text-[11px] text-muted";
      }
    }

    // Quant buttons highlight
    const quantBtns = card.querySelectorAll<HTMLElement>("[data-quant-btn]");
    quantBtns.forEach((btn, i) => {
      if (i === quantIndex) {
        btn.className = "quant-btn rounded px-1.5 py-0.5 text-[10px] font-mono transition-colors border border-accent/30 bg-accent/10 text-accent";
      } else {
        btn.className = "quant-btn rounded px-1.5 py-0.5 text-[10px] font-mono transition-colors border border-transparent text-muted hover:text-secondary";
      }
    });

    // Update VRAM display
    const vramVal = card.querySelector<HTMLElement>("[data-vram-val]");
    if (vramVal) vramVal.textContent = String(vram);

    card.dataset.status = status;
    card.dataset.score = String(score);
    card.dataset.selectedQuant = String(quantIndex);
  }

  function updateAllCards(hw: HardwareInfo) {
    const cards = document.querySelectorAll<HTMLElement>("[data-model-id]");
    cards.forEach((card) => {
      const qi = parseInt(card.dataset.selectedQuant || "2");
      updateModelCard(card, hw, qi);
    });
    updateSummary();
    sortAndAnimateCards();
  }

  function updateSummary() {
    const cards = document.querySelectorAll<HTMLElement>("[data-model-id]");
    const counts: Record<string, number> = { S: 0, A: 0, B: 0, C: 0, D: 0, F: 0 };
    cards.forEach(c => {
      const g = c.dataset.grade || "?";
      if (g in counts) counts[g]++;
    });
    document.getElementById("count-s")!.textContent = String(counts.S);
    document.getElementById("count-a")!.textContent = String(counts.A);
    document.getElementById("count-b")!.textContent = String(counts.B);
    document.getElementById("count-c")!.textContent = String(counts.C);
    document.getElementById("count-d")!.textContent = String(counts.D);
    document.getElementById("count-f")!.textContent = String(counts.F);
    document.getElementById("summary-bar")!.classList.remove("invisible");
  }

  let currentSort = "score";

  function sortAndAnimateCards() {
    const order: Record<string, number> = { "can-run": 0, "tight": 1, "unknown": 2, "cannot-run": 3 };

    function sortComparator(a: HTMLElement, b: HTMLElement): number {
      const cardA = a.querySelector<HTMLElement>("[data-model-id]")!;
      const cardB = b.querySelector<HTMLElement>("[data-model-id]")!;

      switch (currentSort) {
        case "params-asc":
          return parseFloat(cardA.dataset.params || "0") - parseFloat(cardB.dataset.params || "0");
        case "params-desc":
          return parseFloat(cardB.dataset.params || "0") - parseFloat(cardA.dataset.params || "0");
        case "release": {
          const ra = cardA.dataset.release || "";
          const rb = cardB.dataset.release || "";
          return rb.localeCompare(ra);
        }
        case "context":
          return parseInt(cardB.dataset.context || "0") - parseInt(cardA.dataset.context || "0");
        case "toks": {
          const tokA = cardA.querySelector<HTMLElement>("[data-tok-speed]")?.textContent || "";
          const tokB = cardB.querySelector<HTMLElement>("[data-tok-speed]")?.textContent || "";
          const tA = parseInt(tokA.replace(/[^0-9]/g, "")) || 0;
          const tB = parseInt(tokB.replace(/[^0-9]/g, "")) || 0;
          return tB - tA;
        }
        case "vram": {
          const qA = JSON.parse(cardA.dataset.quants || "[]");
          const qB = JSON.parse(cardB.dataset.quants || "[]");
          const vA = qA[parseInt(cardA.dataset.selectedQuant || "2")]?.vramGB || 0;
          const vB = qB[parseInt(cardB.dataset.selectedQuant || "2")]?.vramGB || 0;
          return vA - vB;
        }
        default: { // score
          const sa = order[cardA.dataset.status || "unknown"] ?? 2;
          const sb = order[cardB.dataset.status || "unknown"] ?? 2;
          if (sa !== sb) return sa - sb;
          const scoreA = parseInt(cardA.dataset.score || "0");
          const scoreB = parseInt(cardB.dataset.score || "0");
          if (scoreA !== scoreB) return scoreB - scoreA;
          return parseFloat(cardA.dataset.params || "0") - parseFloat(cardB.dataset.params || "0");
        }
      }
    }

    // Sort both grids independently
    let animIdx = 0;
    for (const gridId of ["models-grid", "models-grid-rest"]) {
      const grid = document.getElementById(gridId);
      if (!grid) continue;
      const links = Array.from(grid.children) as HTMLElement[];
      links.sort(sortComparator);
      links.forEach((link) => {
        const card = link.querySelector<HTMLElement>("[data-model-id]");
        if (card) {
          card.style.animationDelay = `${animIdx * 25}ms`;
          card.classList.add("fade-in");
        }
        grid.appendChild(link);
        animIdx++;
      });
    }
  }

  // ── Filters ────────────────────────────────────────────────

  let activeStatusFilter = "all";
  let activeUseFilter = "all";
  let activeProviderFilter = "all";
  let searchQuery = "";

  function applyFilters() {
    const links = document.querySelectorAll<HTMLElement>("#models-grid > a, #models-grid-rest > a");
    const query = searchQuery.toLowerCase();
    let featuredVisible = 0;
    let restVisible = 0;

    links.forEach(link => {
      const card = link.querySelector<HTMLElement>("[data-model-id]");
      if (!card) return;
      const status = card.dataset.status || "unknown";
      const uses = card.dataset.uses || "";
      const provider = card.dataset.provider || "";
      const name = (card.dataset.modelName || "").toLowerCase();
      const isFeatured = card.dataset.featured === "true";
      let show = true;

      if (query && !name.includes(query)) show = false;
      if (activeStatusFilter === "featured") {
        if (!isFeatured) show = false;
      } else if (activeStatusFilter !== "all" && status !== activeStatusFilter) show = false;
      if (activeUseFilter !== "all" && !uses.includes(activeUseFilter)) show = false;
      if (activeProviderFilter !== "all" && provider !== activeProviderFilter) show = false;

      link.style.display = show ? "" : "none";
      if (show) {
        if (isFeatured) featuredVisible++;
        else restVisible++;
      }
    });

    // Hide divider and rest grid heading when no results in those sections
    const divider = document.getElementById("rest-divider");
    const featuredGrid = document.getElementById("models-grid");
    if (divider) divider.style.display = (featuredVisible === 0 || restVisible === 0) ? "none" : "";
    if (featuredGrid) featuredGrid.style.display = featuredVisible === 0 ? "none" : "";
  }

  function setupFilters() {
    const statusSelect = document.getElementById("filter-status") as HTMLSelectElement;
    const useSelect = document.getElementById("filter-use") as HTMLSelectElement;
    const providerSelect = document.getElementById("filter-provider") as HTMLSelectElement;

    statusSelect?.addEventListener("change", () => {
      activeStatusFilter = statusSelect.value;
      applyFilters();
    });

    useSelect?.addEventListener("change", () => {
      activeUseFilter = useSelect.value;
      applyFilters();
    });

    providerSelect?.addEventListener("change", () => {
      activeProviderFilter = providerSelect.value;
      applyFilters();
    });
  }

  // ── Quant Switching ────────────────────────────────────────

  function setupQuantButtons() {
    document.querySelectorAll<HTMLElement>("[data-quant-btn]").forEach(btn => {
      btn.addEventListener("click", (e) => {
        e.preventDefault();
        e.stopPropagation();
        const card = btn.closest<HTMLElement>("[data-model-id]");
        if (!card || !currentHW) return;
        const qi = parseInt(btn.dataset.quantBtn || "0");
        updateModelCard(card, currentHW, qi);
      });
    });
  }

  // ── Init ───────────────────────────────────────────────────

  async function init() {
    currentHW = await detectHardware();
    updateHardwarePanel(currentHW);
    updateAllCards(currentHW);
  }

  // ── Search ───────────────────────────────────────────────

  function setupSearch() {
    const input = document.getElementById("search-input") as HTMLInputElement;
    if (!input) return;

    input.addEventListener("input", () => {
      searchQuery = input.value.trim();
      applyFilters();
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "/" && document.activeElement !== input && !(document.activeElement instanceof HTMLInputElement) && !(document.activeElement instanceof HTMLTextAreaElement) && !(document.activeElement instanceof HTMLSelectElement)) {
        e.preventDefault();
        input.focus();
      }
      if (e.key === "Escape" && document.activeElement === input) {
        input.blur();
      }
    });
  }

  // ── Sort ─────────────────────────────────────────────────

  function setupSort() {
    const select = document.getElementById("sort-select") as HTMLSelectElement;
    if (!select) return;
    select.addEventListener("change", () => {
      currentSort = select.value;
      sortAndAnimateCards();
    });
  }

  // ── View Mode Toggle ────────────────────────────────────

  type ViewMode = "simple" | "advanced" | "list";
  let viewMode: ViewMode = "simple";

  function applyViewMode() {
    const grids = [document.getElementById("models-grid"), document.getElementById("models-grid-rest")];
    const iconSimple = document.getElementById("view-icon-simple");
    const iconAdvanced = document.getElementById("view-icon-advanced");
    const iconList = document.getElementById("view-icon-list");
    const label = document.getElementById("view-label");

    // Show advanced sections only in advanced mode
    document.querySelectorAll<HTMLElement>("[data-advanced]").forEach(el => {
      el.classList.toggle("hidden", viewMode !== "advanced");
    });

    // Grid vs list layout
    grids.forEach(grid => {
      if (!grid) return;
      if (viewMode === "list") {
        grid.classList.remove("sm:grid-cols-2", "lg:grid-cols-3", "gap-3");
        grid.classList.add("grid-cols-1", "list-view");
      } else {
        grid.classList.remove("grid-cols-1", "list-view");
        grid.classList.add("sm:grid-cols-2", "lg:grid-cols-3", "gap-3");
      }
    });
    document.querySelectorAll<HTMLElement>(".model-card").forEach(card => {
      card.classList.toggle("list-mode", viewMode === "list");
    });

    // Icons
    if (iconSimple) iconSimple.classList.toggle("hidden", viewMode !== "simple");
    if (iconAdvanced) iconAdvanced.classList.toggle("hidden", viewMode !== "advanced");
    if (iconList) iconList.classList.toggle("hidden", viewMode !== "list");
    if (label) {
      const labels: Record<ViewMode, string> = { simple: "Simple", advanced: "Advanced", list: "List" };
      label.textContent = labels[viewMode];
    }
  }

  function setupViewToggle() {
    const btn = document.getElementById("view-toggle");
    if (!btn) return;

    const modes: ViewMode[] = ["simple", "advanced", "list"];

    btn.addEventListener("click", () => {
      const idx = modes.indexOf(viewMode);
      viewMode = modes[(idx + 1) % modes.length];
      applyViewMode();
    });
  }

  // ── Keyboard Navigation ─────────────────────────────────

  function setupKeyboardNav() {
    let focusedCardIndex = -1;

    function getVisibleLinks(): HTMLElement[] {
      return Array.from(document.querySelectorAll<HTMLElement>("#models-grid > a, #models-grid-rest > a")).filter(
        (link) => link.style.display !== "none"
      );
    }

    function focusCard(index: number) {
      const links = getVisibleLinks();
      if (index < 0 || index >= links.length) return;
      focusedCardIndex = index;
      links.forEach((link, i) => {
        const card = link.querySelector<HTMLElement>("[data-model-id]");
        if (card) {
          if (i === index) {
            card.classList.add("ring-1", "ring-accent/40");
            link.scrollIntoView({ block: "nearest", behavior: "smooth" });
          } else {
            card.classList.remove("ring-1", "ring-accent/40");
          }
        }
      });
    }

    function clearFocus() {
      focusedCardIndex = -1;
      document.querySelectorAll<HTMLElement>("[data-model-id]").forEach(card => {
        card.classList.remove("ring-1", "ring-accent/40");
      });
    }

    document.addEventListener("keydown", (e) => {
      const active = document.activeElement;
      if (active instanceof HTMLInputElement || active instanceof HTMLTextAreaElement || active instanceof HTMLSelectElement) return;

      const links = getVisibleLinks();

      switch (e.key) {
        case "j":
          e.preventDefault();
          focusCard(Math.min(focusedCardIndex + 1, links.length - 1));
          break;
        case "k":
          e.preventDefault();
          focusCard(Math.max(focusedCardIndex - 1, 0));
          break;
        case "Enter":
          if (focusedCardIndex >= 0 && focusedCardIndex < links.length) {
            e.preventDefault();
            const link = links[focusedCardIndex] as HTMLAnchorElement;
            if (link.href) window.location.href = link.href;
          }
          break;
        case "Escape":
          clearFocus();
          break;
        case "v":
          e.preventDefault();
          document.getElementById("view-toggle")?.click();
          break;
      }
    });
  }

  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('models-grid')) return;

    activeStatusFilter = "all";
    activeUseFilter = "all";
    activeProviderFilter = "all";
    searchQuery = "";
    currentSort = "score";
    viewMode = "simple";

    setupQuantButtons();
    setupFilters();
    setupSearch();
    setupSort();
    setupViewToggle();
    setupKeyboardNav();
    init();
  });
</script>

