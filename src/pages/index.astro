  }

  .model-card.list-mode [data-card-footer] {
    margin-top: 0;
    padding: 0 1rem 0 0;
    gap: 0.5rem;
  }

  /* List mode grid: remove gap, add top border */
  #models-grid.list-view,
  #models-grid-rest.list-view {
    gap: 0;
    border: 1px solid var(--color-edge);
    border-radius: 0.5rem;
    overflow: hidden;
  }
</style>
