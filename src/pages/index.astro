  .fade-in {
    animation: fadeIn 0.25s ease-out both;
  }

  .model-card[data-status="cannot-run"] {
    opacity: 0.35;
  }

  .model-card[data-status="cannot-run"]:hover {
    opacity: 0.55;
  }

  .filter-select {
    border: 1px solid var(--color-edge);
    background-color: var(--color-surface-card);
    color: var(--color-secondary);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.4;
    padding: 6px 10px;
    border-radius: 6px;
